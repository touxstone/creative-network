generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  name          String?
  bio           String?
  avatar        String?
  profession    String?
  location      String?
  website       String?
  password      String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                 Account[]
  sessions                 Session[]
  posts                    Post[]
  likes                    Like[]
  comments                 Comment[]
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  messageEdits             MessageEditHistory[]
  ownedProjects            Project[]                 @relation("ProjectOwner")
  projectMemberships       ProjectMember[]
  projectCallsCreated      ProjectCall[]             @relation("ProjectCallCreator")
  projectApplications      ProjectApplication[]

  connectionsInitiated Connection[]  @relation("ConnectionsInitiated")
  connectionsReceived  Connection[]  @relation("ConnectionsReceived")
  blockedBy            BlockedUser[] @relation("BlockedBy")
  blocks               BlockedUser[] @relation("Blocks")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Post {
  id        String    @id @default(cuid())
  content   String    @db.Text
  imageUrl  String?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model Connection {
  id        String   @id @default(cuid())
  userAId   String
  userA     User     @relation("ConnectionsInitiated", fields: [userAId], references: [id], onDelete: Cascade)
  userBId   String
  userB     User     @relation("ConnectionsReceived", fields: [userBId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
  @@map("connections")
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("BlockedBy", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocks", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

model Conversation {
  id              String                    @id @default(cuid())
  title           String?
  pinnedMessageId String?
  pinnedMessage   Message?                  @relation("PinnedMessage", fields: [pinnedMessageId], references: [id], onDelete: SetNull)
  participants    ConversationParticipant[]
  messages        Message[]
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([pinnedMessageId])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String               @id @default(cuid())
  conversationId String
  conversation   Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String               @db.Text
  replyToId      String?
  replyTo        Message?             @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]            @relation("MessageReplies")
  pinnedIn       Conversation[]       @relation("PinnedMessage")
  editedAt       DateTime?
  editCount      Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @default(now()) @updatedAt
  editHistory    MessageEditHistory[]

  @@index([conversationId])
  @@index([senderId])
  @@index([replyToId])
  @@index([createdAt])
  @@map("messages")
}

model MessageEditHistory {
  id              String   @id @default(cuid())
  messageId       String
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editorId        String
  editor          User     @relation(fields: [editorId], references: [id], onDelete: Cascade)
  previousContent String   @db.Text
  reason          String?
  createdAt       DateTime @default(now())

  @@index([messageId])
  @@index([editorId])
  @@map("message_edit_history")
}

model Project {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  logline     String?
  description String          @db.Text
  status      String          @default("DEVELOPMENT")
  language    String?
  location    String?
  ownerRole   String?
  ownerId     String
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  links       ProjectLink[]
  calls       ProjectCall[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectLink {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@map("project_links")
}

model ProjectCall {
  id           String               @id @default(cuid())
  projectId    String
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorId    String
  creator      User                 @relation("ProjectCallCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  title        String
  role         String
  discipline   String?
  description  String               @db.Text
  language     String?
  location     String?
  status       String               @default("OPEN")
  deadline     DateTime?
  applications ProjectApplication[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @default(now()) @updatedAt

  @@index([projectId])
  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@map("project_calls")
}

model ProjectApplication {
  id          String      @id @default(cuid())
  callId      String
  call        ProjectCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User        @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  message     String      @db.Text
  status      String      @default("SUBMITTED")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  @@unique([callId, applicantId])
  @@index([applicantId])
  @@index([status])
  @@map("project_applications")
}
